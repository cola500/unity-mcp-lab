# Unity generated
UnityProject/[Ll]ibrary/
UnityProject/[Tt]emp/
UnityProject/\.utmp/
UnityProject/Assets/Resources/PerformanceTest*.json
UnityProject/Assets/Resources/PerformanceTest*.json.meta

# Photon: keep core libs and scripts but drop demos/docs and unused platforms (we only ship Android/macOS).
UnityProject/Assets/Photon/*/Demos/
UnityProject/Assets/Photon/*/Demos.meta
UnityProject/Assets/Photon/PhotonVoice-Documentation.*
UnityProject/Assets/Photon/PhotonVoice/PhotonVoiceLibs/iOS/
UnityProject/Assets/Photon/PhotonVoice/PhotonVoiceLibs/iOS.meta
UnityProject/Assets/Photon/PhotonVoice/PhotonVoiceLibs/VisionOS/
UnityProject/Assets/Photon/PhotonVoice/PhotonVoiceLibs/VisionOS.meta

# Real Stars Skybox Lite (Unity Asset Store — EULA forbids redistributing source).
# Anyone cloning this repo imports the same package from their own My Assets;
# the scene references the material by GUID and resolves once imported.
UnityProject/Assets/Real Stars Skybox/
UnityProject/Assets/Real Stars Skybox.meta

# Piloto Studio Campfires/Torches pack (Unity Asset Store — same EULA).
# Imported locally via Package Manager → My Assets. Not used in the build yet,
# kept available for a future scene-polish slice. Don't commit the source.
UnityProject/Assets/Piloto Studio/
UnityProject/Assets/Piloto Studio.meta
UnityProject/[Oo]bj/
UnityProject/[Bb]uild/
UnityProject/[Bb]uilds/
UnityProject/[Ll]ogs/
UnityProject/[Uu]ser[Ss]ettings/
UnityProject/[Mm]emoryCaptures/
UnityProject/[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!UnityProject/[Ll]ibrary/PackageCache/

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Visual Studio / Rider / IDE
.vs/
.idea/
.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# OS
.DS_Store
Thumbs.db

# Node (mcp-unity server build artefacts live inside Library/, already ignored)
node_modules/

# Claude Code (local-only settings)
.claude/settings.local.json

# MCP server config (contains absolute path + per-machine package hash; use .mcp.example.json)
.mcp.json
