# Unity generated
UnityProject/[Ll]ibrary/
UnityProject/[Tt]emp/
UnityProject/\.utmp/
UnityProject/Assets/Resources/PerformanceTest*.json
UnityProject/Assets/Resources/PerformanceTest*.json.meta

# Photon: keep core libs and scripts but drop demos/docs and unused platforms (we only ship Android/macOS).
UnityProject/Assets/Photon/*/Demos/
UnityProject/Assets/Photon/*/Demos.meta
UnityProject/Assets/Photon/PhotonVoice-Documentation.*
UnityProject/Assets/Photon/PhotonVoice/PhotonVoiceLibs/iOS/
UnityProject/Assets/Photon/PhotonVoice/PhotonVoiceLibs/iOS.meta
UnityProject/Assets/Photon/PhotonVoice/PhotonVoiceLibs/VisionOS/
UnityProject/Assets/Photon/PhotonVoice/PhotonVoiceLibs/VisionOS.meta

# Real Stars Skybox Lite (Unity Asset Store — EULA forbids redistributing source).
# Anyone cloning this repo imports the same package from their own My Assets;
# the scene references the material by GUID and resolves once imported.
UnityProject/Assets/Real Stars Skybox/
UnityProject/Assets/Real Stars Skybox.meta

# Piloto Studio Campfires/Torches pack (Unity Asset Store — same EULA).
# Imported locally via Package Manager → My Assets. Not used in the build yet,
# kept available for a future scene-polish slice. Don't commit the source.
UnityProject/Assets/Piloto Studio/
UnityProject/Assets/Piloto Studio.meta

# WALLCOEUR VFX URP - Fire Package (Unity Asset Store — same EULA).
# Imported locally via Package Manager → My Assets. Evaluated in
# docs/vfx-fire-package-evaluation.md — BiRP-compatible, candidate for
# the next campfire-polish slice. Source must not be committed.
UnityProject/Assets/VFXPACK_FIRE_WALLCOEUR/
UnityProject/Assets/VFXPACK_FIRE_WALLCOEUR.meta

# Shapes — Nature Starter Kit 2 (Unity Asset Store — same EULA).
# Trees, bushes, ground textures used by the forest-atmosphere slice.
# Trimmed locally: kept Nature/, Textures/, Materials/. Removed
# Standard Assets/, Editor/, Scene/, Animations/ (legacy post-processing
# + demo scene, not relevant to our build). Source must not be committed.
UnityProject/Assets/NatureStarterKit2/
UnityProject/Assets/NatureStarterKit2.meta

# Jermesa Studio — Mountain Terrain Rocks and Tree (Unity Asset Store — same EULA).
# Used: rock_set_01..04 + tree_01 (forest slice) and mountain_terrain_01 (this slice's backdrop).
UnityProject/Assets/Mountain Terrain rocks and tree/
UnityProject/Assets/Mountain Terrain rocks and tree.meta

# Walker C — Terra (Unity Asset Store — same EULA).
# Procedural terrain editor; we use only its Example/Textures/Dirt*.tga as a
# ground material. Source not committed. See docs/terra-asset-audit.md.
UnityProject/Assets/Terra/
UnityProject/Assets/Terra.meta

# ithappy — Animals_FREE (Unity Asset Store — same EULA).
# Low-poly animal pack imported via Package Manager → My Assets. Not yet
# placed in the campfire scene; reserved for a future ambience slice.
# Re-importable from My Assets on clone. The com.unity.postprocessing
# package it pulls in (3.5.4) IS committed via Packages/manifest.json so
# builds resolve the transitive dependency even before the source folder
# is re-imported.
UnityProject/Assets/ithappy/
UnityProject/Assets/ithappy.meta

# XR Interaction Toolkit Samples (re-importable via Package Manager — UPM samples).
# Apply Hand Visuals auto-runs Sample.Import() on first use; the imported tree
# is regenerable, so we keep the 10 MB of demo scenes / textures / shaders out
# of the repo. The combined-mesh asset we derive from UniversalController.fbx
# IS committed (Assets/Models/HandsControllerMesh.asset) — that's the artefact
# the scene references. See docs/hand-visuals-slice.md.
UnityProject/Assets/Samples/
UnityProject/Assets/Samples.meta
UnityProject/[Oo]bj/
UnityProject/[Bb]uild/
UnityProject/[Bb]uilds/
UnityProject/[Ll]ogs/
UnityProject/[Uu]ser[Ss]ettings/
UnityProject/[Mm]emoryCaptures/
UnityProject/[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!UnityProject/[Ll]ibrary/PackageCache/

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Local distribution artifacts (friend-test packages: APK + zip + bundled docs).
# Rebuilt fresh per session via scripts/build-quest.sh + a manual `cp + zip`
# pass; the docs that get bundled live in docs/ and are committed there.
dist/

# Debug logs pulled from the Quest via `adb pull`. Per-session artefacts —
# may contain device names + timestamps from real test runs. Investigate
# locally, share manually if relevant; don't track.
quest-logs/

# Visual Studio / Rider / IDE
.vs/
.idea/
.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# OS
.DS_Store
Thumbs.db

# Node (mcp-unity server build artefacts live inside Library/, already ignored)
node_modules/

# Claude Code (local-only settings)
.claude/settings.local.json

# MCP server config (contains absolute path + per-machine package hash; use .mcp.example.json)
.mcp.json
